{
  "model": "openrouter/anthropic/claude-sonnet-4-6",
  "workspace": "./tmp/ui-debugger-mcp",
  "targets": {
    "web": {
      "adapter": "browser",
      "url": "http://localhost:3000",
      "headless": true,
      "debugLogin": { "param": "debug-ai" }
    },
    "desktop": {
      "adapter": "desktop",
      "launch": "my-desktop-app"
    },
    "mobile": {
      "adapter": "desktop",
      "launch": "emulator @my-avd",
      "window": "My App"
    }
  }
}
